// ── Bio photo
document.getElementById('bioPhoto').style.backgroundImage = "url('data:image/jpeg;base64,')";

// ══ HERO SEQUENCE ══
// MAKE SPACE always visible. Photos slowly fade in behind it, hold, fade out.
// Each photo: 3s fade in, 4s hold, 3s fade out = 10s total, then next.
(function() {
  const slides = [
    document.getElementById('hs0'),
    document.getElementById('hs1'),
    document.getElementById('hs2')
  ];
  let current = 0;

  function showSlide(idx) {
    // Fade in
    slides[idx].classList.add('active');
    // After 7s (3s fade-in + 4s hold), fade out
    setTimeout(() => {
      slides[idx].classList.remove('active');
      // After 3s fade-out, show next
      setTimeout(() => {
        current = (current + 1) % slides.length;
        showSlide(current);
      }, 3000);
    }, 7000);
  }

  // Start first photo after a 1s pause (so black + words show first)
  setTimeout(() => showSlide(0), 1000);
})();

// ══ SCROLL PARALLAX on hero ══
const hero = document.getElementById('hero');
window.addEventListener('scroll', () => {
  const y  = window.scrollY;
  const vh = window.innerHeight;
  if (y <= vh) {
    const p = y / vh;
    hero.style.transform = `scale(${1 - p * 0.05})`;
    hero.style.opacity   = `${1 - p * 1.1}`;
  }
  document.getElementById('nav').classList.toggle('scrolled', y > 60);
}, {passive:true});

// ══ RIVER SCROLL SPEED ══
// Cursor scroll over a strip speeds it up temporarily
(function(){
  document.querySelectorAll('.river-strip, .sow-strip').forEach(strip => {
    const tracks = strip.querySelectorAll('.river-track');
    let base = {};
    tracks.forEach(t => {
      const spd = parseFloat(getComputedStyle(t).getPropertyValue('--spd')) || 32;
      base[t] = spd;
    });
    strip.addEventListener('wheel', e => {
      // Only intercept if scrolling is primarily horizontal, let vertical pass
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
        // Vertical scroll — speed up strips but don't block page scroll
        const boost = Math.abs(e.deltaY) * 0.04;
        tracks.forEach(t => {
          const cur = parseFloat(t.style.getPropertyValue('--spd')) || base[t];
          const next = Math.max(4, cur - boost);
          t.style.setProperty('--spd', next + 's');
          clearTimeout(t._rst);
          t._rst = setTimeout(() => { t.style.setProperty('--spd', base[t] + 's'); }, 800);
        });
        // Do NOT call e.preventDefault() — let page scroll through
      }
    }, {passive:true});
  });
})();

// ══ PILL HOVER → FEATURE PANEL ══
(function(){
  const data = {
    'wb-photography': {
      brand:     { title:'Brand',     body:'Visual identity work for cafés and hospitality brands — from launch campaigns to ongoing content partnerships.',         cta:'See brand work ↗',     href:'#' },
      lifestyle: { title:'Lifestyle', body:'Documentary and editorial photography capturing the warmth, ritual, and culture of everyday café life.',                 cta:'See lifestyle work ↗', href:'#' },
      menu:      { title:'Menu',      body:'Revenue-driving food and beverage photography on white — clean, purposeful images that sell.',                           cta:'Visit Solo on White ↗', href:'https://soloonwhite.com' }
    },
    'wb-cafe-strategy': {
      spill:      { title:'SPILL Coffee Magazine', body:'A media brand documenting the people, places, and ideas behind independent café culture.',                      cta:'Explore SPILL ↗',      href:'#' },
      consulting: { title:'Consulting',            body:'Fifteen years opening cafés — strategy, ops, team culture, and the systems that make hospitality feel human.', cta:'Work together ↗',      href:'#contact' },
      speaking:   { title:'Speaking',              body:'Keynotes and workshops on the Culture of Care, third-place philosophy, and designing for connection.',          cta:'Book a talk ↗',        href:'#contact' }
    },
    'wb-connection': {
      makespace: { title:'Make Space', body:'A philosophy and practice for building rooms — physical and relational — where people can actually show up.',    cta:'Explore Make Space ↗', href:'#' },
      slowcafe:  { title:'Slow Café',  body:'A podcast on third-place philosophy, the art of slowing down, and the spaces that hold communities together.', cta:'Listen ↗',             href:'#' }
    }
  };

  let closeTimer = null;

  function openPanel(blockId, key) {
    clearTimeout(closeTimer);
    const block = document.getElementById(blockId);
    if (!block) return;
    const panelId = 'fp-' + blockId.replace('wb-','');
    const panel = document.getElementById(panelId);
    if (!panel) return;
    const d = data[blockId]?.[key];
    if (!d) return;

    // Update text
    const ttl = panel.querySelector('.fp-title');
    const bod = panel.querySelector('.fp-body');
    const cta = panel.querySelector('.fp-cta');
    if (ttl) ttl.textContent = d.title;
    if (bod) bod.textContent = d.body;
    if (cta) { cta.textContent = d.cta; cta.href = d.href; }

    // Swap image
    panel.querySelectorAll('.fp-img').forEach(img => img.classList.remove('active'));
    const target = panel.querySelector(`.fp-img[data-key="${key}"]`);
    if (target) target.classList.add('active');

    // Open panel
    block.classList.add('panel-open');

    // Highlight active pill
    document.querySelectorAll('.wm-tag').forEach(t => t.classList.remove('active'));
    document.querySelectorAll(`.wm-tag[data-panel="${blockId}"][data-key="${key}"]`).forEach(t => t.classList.add('active'));
  }

  function closePanel(blockId) {
    closeTimer = setTimeout(() => {
      const block = document.getElementById(blockId);
      if (block) block.classList.remove('panel-open');
      document.querySelectorAll('.wm-tag').forEach(t => t.classList.remove('active'));
    }, 600);
  }

  document.querySelectorAll('.wm-tag[data-panel]').forEach(tag => {
    const blockId = tag.dataset.panel;
    const key = tag.dataset.key;
    tag.addEventListener('mouseenter', () => openPanel(blockId, key));
    tag.addEventListener('mouseleave', () => closePanel(blockId));
    // Keep panel open when hovering over it
    const block = document.getElementById(blockId);
    if (block) {
      const panelId = 'fp-' + blockId.replace('wb-','');
      const panel = document.getElementById(panelId);
      if (panel) {
        panel.addEventListener('mouseenter', () => clearTimeout(closeTimer));
        panel.addEventListener('mouseleave', () => closePanel(blockId));
      }
    }
  });
})();

// ══ SECTION-BASED MARQUEE PLAY/PAUSE ══
(function(){
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      const tracks = e.target.querySelectorAll('.river-track');
      tracks.forEach(t => {
        t.style.animationPlayState = e.isIntersecting ? 'running' : 'paused';
      });
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.strips-wrap').forEach(wrap => {
    // Start paused — observer will activate when in view
    wrap.querySelectorAll('.river-track').forEach(t => {
      t.style.animationPlayState = 'paused';
    });
    sectionObs.observe(wrap);
  });
})();

// ══ SCROLL REVEALS ══
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
}, {threshold:.12, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
