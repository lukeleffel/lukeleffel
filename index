<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luke Leffel</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0908;
  --white:#f2ede6;
  --dim:rgba(242,237,230,.42);
  --muted:rgba(242,237,230,.22);
  --accent:#d4688a;
  --accent2:#c8a96e;
  --grad:linear-gradient(135deg,#7b8fe8,#e05fa0);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:"DM Sans",sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* ══ NAV ══ */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;justify-content:space-between;align-items:center;padding:1.8rem 3rem;transition:background .4s}
nav.scrolled{background:rgba(10,9,8,.85);backdrop-filter:blur(12px)}
.nav-logo{font-family:"Bebas Neue",sans-serif;font-size:1.05rem;letter-spacing:.2em;color:var(--white);text-decoration:none}
.nav-links{display:flex;gap:2.5rem;align-items:center}
.nav-link{font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-link:hover{color:var(--white)}
.nav-cta{font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--bg);background:var(--accent);padding:.5rem 1.2rem;text-decoration:none;border-radius:1px;transition:background .2s}
.nav-cta:hover{background:var(--white)}

/* ══ HERO ══ */
.s-hero{position:relative;height:100vh;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--bg)}

/* Photos sit behind text, fade in/out slowly */
.h-slide{
  position:absolute;inset:0;
  background:center/cover no-repeat;
  filter:grayscale(1) brightness(.45) contrast(1.1);
  opacity:0;
  transition:opacity 3s ease;
  z-index:0;
}
.h-slide.active{opacity:1}

/* Vignette over photos */
.hero-vig{
  position:absolute;inset:0;z-index:1;pointer-events:none;
  background:radial-gradient(ellipse at center,transparent 20%,rgba(10,9,8,.7) 100%);
}

/* MAKE SPACE — always visible, on top */
.hero-words{
  position:relative;z-index:2;
  text-align:center;pointer-events:none;
}
.hw-make{
  display:block;font-family:"Bebas Neue",sans-serif;
  font-size:clamp(6rem,16vw,20rem);line-height:.85;letter-spacing:.04em;
  background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  opacity:0;animation:fadeUp 1s ease .3s forwards;
}
.hw-space{
  display:block;font-family:"Bebas Neue",sans-serif;
  font-size:clamp(6rem,16vw,20rem);line-height:.85;letter-spacing:.04em;
  color:var(--white);
  opacity:0;animation:fadeUp 1s ease .6s forwards;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes goLeft{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes goRight{from{transform:translateX(-50%)}to{transform:translateX(0)}}

/* Scroll cue */
.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
  z-index:3;display:flex;flex-direction:column;align-items:center;gap:.6rem;
  opacity:0;animation:fadeUp .8s ease 2s forwards;
}
.hero-scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,rgba(212,104,138,.7),transparent);animation:sp 2s ease infinite}
@keyframes sp{0%,100%{opacity:.3}50%{opacity:1}}
.hero-scroll-txt{font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted)}

/* ══ BIO — Bartlett layout ══ */
.s-bio{
  position:relative;z-index:10;background:var(--bg);
  display:grid;grid-template-columns:55% 45%;min-height:100vh;
}
.bio-left{
  display:flex;flex-direction:column;justify-content:center;
  padding:8rem 3.5rem 6rem;
}
.bio-type{
  font-family:"Bebas Neue",sans-serif;
  font-size:clamp(2.8rem,5vw,6.2rem);
  line-height:.94;letter-spacing:.01em;color:var(--white);
}
.bio-type .hl{color:var(--accent)}
.bio-type .hl2{
  background:var(--grad);-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;
}
.bio-sub{
  margin-top:2.5rem;font-size:clamp(.85rem,1.1vw,1rem);
  font-weight:300;line-height:1.75;color:var(--dim);max-width:46ch;
}
.bio-sub em{font-style:italic;color:rgba(242,237,230,.7)}
.bio-cta{
  margin-top:2.8rem;display:inline-flex;align-items:center;gap:.75rem;
  font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;
  color:var(--accent);text-decoration:none;
  border-bottom:1px solid var(--accent);padding-bottom:2px;width:fit-content;
  transition:color .2s,border-color .2s;
}
.bio-cta:hover{color:var(--white);border-color:var(--white)}
.bio-right{position:relative;overflow:hidden}
.bio-photo{
  position:absolute;inset:0;
  background:center 12%/cover no-repeat;
  filter:grayscale(1) brightness(1.15) contrast(1.05);
}
.bio-photo::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(to right,var(--bg) 0%,transparent 25%),
             linear-gradient(to top,var(--bg) 0%,transparent 30%);
}

/* ══ PROJECT LIST ══ */
.s-projects{padding:0 3.5rem 8vw;position:relative;z-index:10;background:var(--bg)}
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;border:1px solid rgba(242,237,230,.07)}
.proj-item{padding:2rem 1.8rem;border-right:1px solid rgba(242,237,230,.07);text-decoration:none;color:inherit;display:block;transition:background .3s}
.proj-item:hover{background:rgba(212,104,138,.04)}
.proj-item:nth-child(3n){border-right:none}
.proj-num{font-family:"Bebas Neue",sans-serif;font-size:.75rem;letter-spacing:.2em;color:var(--muted);margin-bottom:.6rem}
.proj-name{font-family:"Bebas Neue",sans-serif;font-size:1.4rem;letter-spacing:.04em;line-height:1;margin-bottom:.7rem;transition:color .2s}
.proj-item:hover .proj-name{color:var(--accent)}
.proj-desc{font-size:.78rem;font-weight:300;color:var(--dim);line-height:1.65}


/* ══ RIVER ══ */
.world-moment{padding:5vw 3.5rem 2.2vw;position:relative;z-index:10}
.wm-title{font-family:"DM Sans",sans-serif;font-size:clamp(1.6rem,3.2vw,3.2rem);font-weight:300;line-height:1;letter-spacing:.06em;text-transform:uppercase;margin-bottom:1.2rem}
.wm-title .g{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.wm-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.4rem}
.wm-tag{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--white);text-decoration:none;padding:.35rem .9rem;border-radius:20px;background:linear-gradient(135deg,rgba(123,143,232,.18),rgba(224,95,160,.18));border:1px solid rgba(212,104,138,.3);transition:background .25s,border-color .25s}
.wm-tag:hover{background:linear-gradient(135deg,rgba(123,143,232,.35),rgba(224,95,160,.35));border-color:rgba(212,104,138,.7)}
.river-strip{position:relative;overflow:hidden;padding:2px 0}
.river-strip::before,.river-strip::after{content:"";position:absolute;top:0;bottom:0;width:10vw;z-index:2;pointer-events:none}
.river-strip::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
.river-strip::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
.river-track{display:flex;gap:10px;width:max-content}
.river-track.rl{animation:goLeft var(--spd,60s) linear infinite}
.river-track.rr{animation:goLeft var(--spd,70s) linear infinite}
.river-track.rs{animation:goLeft var(--spd,90s) linear infinite}
.rc{flex-shrink:0;border-radius:3px;overflow:hidden;position:relative;background:#1a1612}
.rc img{display:block;width:100%;height:100%;object-fit:cover;filter:saturate(.55) brightness(.72);transition:filter .6s cubic-bezier(.16,1,.3,1),transform .6s cubic-bezier(.16,1,.3,1)}
.rc:hover img{filter:saturate(.9) brightness(.88);transform:scale(1.04)}
/* ══ FEATURE PANEL (pill hover — overlays strips) ══ */
.world-block{position:relative}
.strips-wrap{position:relative}
.strips-wrap{position:relative}
.feature-panel{
  position:absolute;inset:0;
  opacity:0;pointer-events:none;
  transition:opacity .45s ease;
  z-index:10;
}
.world-block.panel-open .feature-panel{
  opacity:1;pointer-events:auto;
}
.fp-img{
  position:absolute;inset:0;
  background:center/cover no-repeat;
  transition:opacity .45s ease;
  opacity:0;
}
.fp-img.active{opacity:1}
.fp-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to right, rgba(10,9,8,.88) 0%, rgba(10,9,8,.5) 55%, transparent 100%);
  display:flex;flex-direction:column;justify-content:center;
  padding:3rem 4rem;
}
.fp-eyebrow{font-size:.58rem;letter-spacing:.26em;text-transform:uppercase;color:var(--accent);margin-bottom:.8rem}
.fp-title{font-family:"Bebas Neue",sans-serif;font-size:clamp(2.5rem,5vw,5rem);line-height:.92;letter-spacing:.03em;margin-bottom:1rem}
.fp-body{font-size:.88rem;font-weight:300;color:var(--dim);max-width:34ch;line-height:1.7;margin-bottom:1.6rem}
.fp-cta{display:inline-flex;align-items:center;gap:.6rem;font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;color:var(--white);text-decoration:none;background:linear-gradient(135deg,rgba(123,143,232,.25),rgba(224,95,160,.25));border:1px solid rgba(212,104,138,.4);padding:.55rem 1.2rem;border-radius:20px;transition:background .25s,border-color .25s;width:fit-content}
.fp-cta:hover{background:linear-gradient(135deg,rgba(123,143,232,.45),rgba(224,95,160,.45));border-color:rgba(212,104,138,.8)}
.wm-tag.active{background:linear-gradient(135deg,rgba(123,143,232,.45),rgba(224,95,160,.45));border-color:rgba(212,104,138,.8)}
/* ══ CTA ══ */

/* ══ CTA ══ */

/* ══ CTA ══ */
.s-cta{padding:10vw 3.5rem 12vw;position:relative;overflow:hidden;z-index:10;background:var(--bg)}
.cta-glow{position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(212,104,138,.08) 0%,transparent 70%);bottom:-200px;right:-100px;pointer-events:none}
.cta-label{font-size:.63rem;letter-spacing:.28em;text-transform:uppercase;color:var(--accent2);margin-bottom:2.5rem;display:flex;align-items:center;gap:1rem}
.cta-label::before{content:"";width:36px;height:1px;background:var(--accent2);display:block}
.cta-head{font-family:"Bebas Neue",sans-serif;font-size:clamp(4.5rem,11vw,14rem);line-height:.88;letter-spacing:.02em;margin-bottom:3rem;position:relative;z-index:2}
.cta-head span{display:block;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.cta-email{font-size:clamp(1rem,1.8vw,1.4rem);font-weight:300;color:var(--dim);text-decoration:none;letter-spacing:.06em;border-bottom:1px solid rgba(242,237,230,.15);padding-bottom:.25rem;transition:color .3s,border-color .3s;position:relative;z-index:2}
.cta-email:hover{color:var(--white);border-color:var(--accent)}

footer{border-top:1px solid rgba(242,237,230,.06);padding:2.5rem 3.5rem;display:flex;justify-content:space-between;align-items:center;position:relative;z-index:10;background:var(--bg)}
.f-logo{font-family:"Bebas Neue",sans-serif;font-size:1rem;letter-spacing:.18em;color:rgba(242,237,230,.18)}
.f-links{display:flex;gap:2rem;list-style:none}
.f-links a{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,237,230,.2);text-decoration:none;transition:color .2s}
.f-links a:hover{color:var(--white)}
.f-copy{font-size:.63rem;color:rgba(242,237,230,.1)}

.reveal{opacity:0;transform:translateY(28px);transition:opacity .9s ease,transform .9s cubic-bezier(.16,1,.3,1)}
.reveal.on{opacity:1;transform:none}
.rd1{transition-delay:.1s}.rd2{transition-delay:.22s}.rd3{transition-delay:.34s}
.rd4{transition-delay:.46s}.rd5{transition-delay:.58s}
</style>
</head>
